{
  "name": "@pixi-ui-editor/runtime-pixi",
  "version": "0.1.1",
  "description": "PixiJS runtime that renders Pixi UI Editor scene documents in a game.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexMariacho/pixi-ui-editor.git",
    "directory": "packages/runtime-pixi"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.3.10",
    "@pixi-ui-editor/schema": "workspace:*",
    "@pixi/layout": "3.2.1",
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "2.3.2",
    "pixi.js": "^8.19.0",
    "yoga-layout": "^3.2.1"
  }
}
